{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=your_database_name;Username=your_username;Password=your_password"
  },
  "RedisConnection": "localhost:6379",

  "JwtSettings": {
    "Secret": "your_jwt_secret_key_here",
    "Issuer": "your_api_name",
    "Audience": "your_client_name",
    "ExpiryInDays": 7
  },

  "DemoAccounts": {
    "Admin": {
      "Email": "your_admin_email@example.com",
      "Password": "YourSecureAdminPassword"
    },
    "Manager": {
      "Email": "your_manager_email@example.com",
      "Password": "YourSecureManagerPassword"
    },
    "Staff": {
      "Email": "your_staff_email@example.com",
      "Password": "YourSecureStaffPassword"
    }
  },

  "AllowedHosts": "*",

  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/app-.log",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      }
    ]
  }
}
